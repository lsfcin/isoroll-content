{
  "PIPELINE_NOTE": "Path A — Blender render stylization via ControlNet Tile. Input is a Blender RGBA render (256x384). Node 12 upscales to 512x768 with lanczos before ControlNet — prevents double-character artifacts from empty canvas space. ControlNet Tile preserves structure; img2img denoise 0.65-0.80 applies dark fantasy style. REPLACE_INPUT_IMAGE = uploaded Blender PNG. REPLACE_PROMPT = character/asset description.",

  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "dreamshaper_8.safetensors"
    }
  },

  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "REPLACE_PROMPT, isometric game sprite, dark fantasy RPG, illustrated style, Hades game art, clean lineart, cel shaded, sharp focus",
      "clip": ["1", 1]
    }
  },

  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "blurry, photo-realistic, 3d render, nsfw, watermark, text, cropped, bad anatomy, deformed, ugly, low quality",
      "clip": ["1", 1]
    }
  },

  "4": {
    "class_type": "ControlNetLoader",
    "inputs": {
      "control_net_name": "control_v11f1e_sd15_tile.pth"
    }
  },

  "5": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "REPLACE_INPUT_IMAGE",
      "upload": "image"
    }
  },

  "12": {
    "class_type": "ImageScale",
    "inputs": {
      "image": ["5", 0],
      "upscale_method": "lanczos",
      "width": 512,
      "height": 768,
      "crop": "disabled"
    }
  },

  "6": {
    "class_type": "TilePreprocessor",
    "inputs": {
      "image": ["12", 0],
      "pyrUp_iters": 3,
      "resolution": 512
    }
  },

  "7": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive": ["2", 0],
      "negative": ["3", 0],
      "control_net": ["4", 0],
      "image": ["6", 0],
      "strength": 0.9,
      "start_percent": 0.0,
      "end_percent": 1.0
    }
  },

  "8": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": ["12", 0],
      "vae": ["1", 2]
    }
  },

  "9": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0,
      "steps": 25,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 0.45,
      "model": ["1", 0],
      "positive": ["7", 0],
      "negative": ["7", 1],
      "latent_image": ["8", 0]
    }
  },

  "10": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["9", 0],
      "vae": ["1", 2]
    }
  },

  "11": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["10", 0],
      "filename_prefix": "isoroll/pathA"
    }
  }
}
