# ── Generated outputs (not versioned) ─────────────────────────────────────────
# Raw generated images in every output subfolder
outputs/**/*.png
outputs/**/*.jpg
outputs/**/*.jpeg
outputs/**/*.webp
outputs/**/*.mp4
outputs/**/*.webm
outputs/**/*.gif

# Benchmark images ARE versioned (curated reference set)
!outputs/benchmark/images/*.png
!outputs/benchmark/images/*.jpg
!outputs/benchmark/images/*.jpeg
!outputs/benchmark/images/*.webp

# Benchmark support scripts and manifests ARE versioned
!outputs/benchmark/README.md
!outputs/benchmark/manifest.json
!outputs/benchmark/run_*.py
!outputs/benchmark/run_*.pyi
!outputs/benchmark/*/manifest.json
!outputs/benchmark/*/EVALUATION.md

chars/
output/
temp/
*.zip

# ── Python / runtime noise ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# ── Local machine config ──────────────────────────────────────────────────────
.env
.env.*
*.log
