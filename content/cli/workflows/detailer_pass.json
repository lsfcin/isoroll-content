{
  "PIPELINE_NOTE": "Post-process detailer pass. Upscales 4x with UltraSHarp, scales back to 2x target, THEN runs FaceDetailer at high-res where face is large enough for SD to work with. Low-res FaceDetailer (skipped here) damages masked/hooded faces because the face region is only ~50px. REPLACE_INPUT_IMAGE = generated image to fix. REPLACE_PROMPT = same prompt used for generation.",

  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "lyriel_v16.safetensors"
    }
  },

  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "REPLACE_PROMPT, detailed face, sharp eyes, clean lineart, dark fantasy illustrated style",
      "clip": ["1", 1]
    }
  },

  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "blurry, deformed face, bad eyes, bad hands, extra fingers, missing fingers, fused fingers, mutated hands, low quality, ugly, nsfw, artifact, horn, distorted hood",
      "clip": ["1", 1]
    }
  },

  "4": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "REPLACE_INPUT_IMAGE",
      "upload": "image"
    }
  },

  "5": {
    "class_type": "UpscaleModelLoader",
    "inputs": {
      "model_name": "4xUltrasharp_4xUltrasharpV10.pt"
    }
  },

  "6": {
    "class_type": "ImageUpscaleWithModel",
    "inputs": {
      "upscale_model": ["5", 0],
      "image": ["4", 0]
    }
  },

  "7": {
    "class_type": "ImageScale",
    "inputs": {
      "image": ["6", 0],
      "upscale_method": "lanczos",
      "width": 1024,
      "height": 1536,
      "crop": "disabled"
    }
  },

  "8": {
    "class_type": "UltralyticsDetectorProvider",
    "inputs": {
      "model_name": "bbox/face_yolov8m.pt"
    }
  },

  "9": {
    "class_type": "UltralyticsDetectorProvider",
    "inputs": {
      "model_name": "bbox/hand_yolov8s.pt"
    }
  },

  "10": {
    "class_type": "FaceDetailer",
    "inputs": {
      "image": ["7", 0],
      "model": ["1", 0],
      "clip": ["1", 1],
      "vae": ["1", 2],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "bbox_detector": ["8", 0],
      "guide_size": 512,
      "guide_size_for": true,
      "max_size": 1024,
      "seed": 0,
      "steps": 20,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 0.35,
      "feather": 8,
      "noise_mask": true,
      "force_inpaint": true,
      "bbox_threshold": 0.5,
      "bbox_dilation": 10,
      "bbox_crop_factor": 3.0,
      "sam_detection_hint": "center-1",
      "sam_dilation": 0,
      "sam_threshold": 0.93,
      "sam_bbox_expansion": 0,
      "sam_mask_hint_threshold": 0.7,
      "sam_mask_hint_use_negative": "False",
      "drop_size": 10,
      "wildcard": "",
      "cycle": 1
    }
  },

  "11": {
    "class_type": "FaceDetailer",
    "inputs": {
      "image": ["10", 0],
      "model": ["1", 0],
      "clip": ["1", 1],
      "vae": ["1", 2],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "bbox_detector": ["9", 0],
      "guide_size": 512,
      "guide_size_for": true,
      "max_size": 1024,
      "seed": 0,
      "steps": 20,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 0.30,
      "feather": 8,
      "noise_mask": true,
      "force_inpaint": true,
      "bbox_threshold": 0.5,
      "bbox_dilation": 12,
      "bbox_crop_factor": 2.5,
      "sam_detection_hint": "center-1",
      "sam_dilation": 0,
      "sam_threshold": 0.93,
      "sam_bbox_expansion": 0,
      "sam_mask_hint_threshold": 0.7,
      "sam_mask_hint_use_negative": "False",
      "drop_size": 10,
      "wildcard": "",
      "cycle": 1
    }
  },

  "12": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["11", 0],
      "filename_prefix": "isoroll/detailed"
    }
  }
}
